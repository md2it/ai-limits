{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Limits",
  "version": "0.1.0",
  "identifier": "com.ai-limits.desktop",
  "build": {
    "beforeDevCommand": "python3 -m http.server 1420 --directory frontend",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AI Limits",
        "width": 900,
        "height": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  }
}
