# GitHub Actions secrets for signed + notarized macOS builds.
# See docs/devops/macos-signing.md for setup steps.

# Developer ID Application certificate exported from Keychain as .p12, then:
#   openssl base64 -A -in certificate.p12 | pbcopy
APPLE_CERTIFICATE=

# Password used when exporting the .p12 file.
APPLE_CERTIFICATE_PASSWORD=

# Random password for the temporary CI keychain (any strong string).
KEYCHAIN_PASSWORD=

# Do not set APPLE_SIGNING_IDENTITY in GitHub secrets when using APPLE_CERTIFICATE.
# Tauri derives the identity from the imported .p12 automatically.

# 10-character Team ID from developer.apple.com → Membership.
APPLE_TEAM_ID=

# App Store Connect → Users and Access → Integrations → Individual Keys
APPLE_API_KEY_ID=
APPLE_API_ISSUER=

# Full contents of AuthKey_<APPLE_API_KEY_ID>.p8 (including BEGIN/END lines).
APPLE_API_KEY_CONTENT=
